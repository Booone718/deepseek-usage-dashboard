DATA_DIR=data
TZ=Asia/Shanghai
UPLOAD_RETENTION_DAYS=365
CLEANUP_ENABLED=true

# Set a password to enable HTTP Basic Auth.
# APP_PASSWORD=change-me

# Optional single-account daily auto import.
# Keep the cURL file local on the server; never commit it.
AUTO_IMPORT_ENABLED=false
DEEPSEEK_EXPORT_CURL_FILE=/app/secrets/deepseek-export.curl
DEEPSEEK_SINGLE_ACCOUNT_USER_ID=deepseek-main
AUTO_IMPORT_DAILY_TIME=20:30
# Defaults to TZ. Set only when auto import should use a different timezone.
# AUTO_IMPORT_TIMEZONE=Asia/Shanghai
